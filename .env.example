# Which published image tag to run for the gateway and fleet browser images
# (ghcr.io/jra3/chikin{,-gateway}:<tag>). Defaults to an immutable per-commit
# `sha-<short>` tag (CI publishes one for BOTH first-party images on every main
# build) so installs are reproducible instead of silently tracking a moved
# `latest`. Bump it to a newer `sha-<short>` to upgrade, or set `latest` to
# always ride the newest build on main. (No semver release tags are published
# yet — an immutable v* release scheme would be a cleaner long-term default.)
CHIKIN_VERSION=sha-e1b3e92

# Bearer token clients must present to the gateway (Authorization: Bearer <token>).
# The gateway binds 127.0.0.1 only, so this is OPTIONAL: leave it empty for
# no-auth local use, or generate one to require it:  openssl rand -hex 32
#
# SCOPE: the token gates the MCP endpoint (/b/<name>/) ONLY. The fleet dashboard
# (/) and the noVNC control proxy (/vnc/<name>/) are browser-driven and stay
# reachable without it — they rely on loopback binding + an Origin/Host guard.
# So GATEWAY_TOKEN does NOT secure a shared/multi-user host; keep the box
# single-trusted-user regardless of whether a token is set.
GATEWAY_TOKEN=

# Optional: extra browser Origins trusted by ALL the gateway's Origin/Host
# guards — the fleet dashboard (/), the noVNC control websocket (/vnc/<name>/),
# and the MCP endpoint's Host check (/b/<name>/) — beyond the default loopback
# set (http://127.0.0.1:<port>, localhost, [::1]). Comma-separated full origins,
# e.g. for reaching the gateway over an SSH tunnel under a custom hostname.
# Leave empty for the loopback-only default.
GATEWAY_EXTRA_ORIGINS=

# Golden-profile seed: a Docker volume cloned into every new browser so they
# start logged in. Empty = off. Populate it with bin/chikin-snapshot.
#
# Changing this only takes effect when the gateway container is RECREATED from
# this directory (docker compose up -d --force-recreate gateway) — container env
# is fixed at create time. Verify what the running gateway actually got with
#   curl -s localhost:8080/healthz | grep seedVolume
# (or the dashboard's "runtime config" panel); it also logs the ON/OFF state at
# startup. A gateway created elsewhere silently ran with seeding off for weeks.
SEED_VOLUME=

# Renderer-sandbox policy (H1 hardening): auto|on|off.
#   auto (default) — run Chrome sandboxed where the host permits unprivileged
#                    user namespaces, else fall back to --no-sandbox (loud WARN).
#   on             — force sandboxed; fail loudly if the host can't support it.
#   off            — force --no-sandbox (pre-hardening behavior).
CHIKIN_SANDBOX=auto

# Optional tuning (defaults shown).
MAX_FLEET=8
IDLE_TTL_SEC=900
REAP_INTERVAL_SEC=30
PROVISION_TIMEOUT_SEC=90
WINDOW_SIZE=1920,1080
LOG_LEVEL=info

# Per-browser resource caps (M3). MAX_FLEET bounds how MANY browsers run; these
# bound what any ONE browser may consume, so a single hostile or runaway page
# can't OOM, fork-bomb, or CPU-starve the host and take down every other
# client's browser. Set any knob to 0 to disable just that cap.
#
# BROWSER_MEMORY_MB: hard RAM cap (swap is pinned equal, so no swap escape).
#   Must exceed the 2g /dev/shm each browser gets — that tmpfs is charged to the
#   same cgroup — so 3072 leaves ~1g of headroom above a full shm for Chrome.
BROWSER_MEMORY_MB=3072
# BROWSER_PIDS_LIMIT: max processes/threads per browser (the fork-bomb guard).
BROWSER_PIDS_LIMIT=512
# BROWSER_CPUS: CPU cap in cores (fractions allowed, e.g. 1.5).
BROWSER_CPUS=2.0
# BROWSER_NOFILE: open-file-descriptor ceiling (soft=hard). Chrome is fd-hungry,
#   so keep this generous; it bounds abuse without breaking normal pages.
BROWSER_NOFILE=8192
