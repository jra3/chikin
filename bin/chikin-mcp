#!/usr/bin/env bash
# chikin-mcp — stdio MCP server that bridges this Claude instance to its OWN
# browser behind the chikin gateway. Register once at user scope:
#
#   claude mcp add --scope user chikin -- ~/.local/bin/chikin-mcp
#
# Then EVERY Claude instance automatically gets a unique, multiplexed browser.
# The name defaults to inst-<claude pid> (unique per running instance, stable
# for its lifetime). Pin a specific sticky browser by exporting CHIKIN_NAME
# (the chikin-claude wrapper just does that for you).
#
# Env:
#   CHIKIN_GATEWAY  gateway base URL (default http://localhost:8080)
#   CHIKIN_NAME     explicit browser name (default inst-<ppid>)
#   CHIKIN_TOKEN    bearer token, if the gateway has GATEWAY_TOKEN set
set -euo pipefail

# Resolve this script's real location, following symlinks (it's symlinked onto
# PATH, e.g. ~/.local/bin/chikin-mcp -> <repo>/bin/chikin-mcp). Portable across
# GNU and BSD/macOS — macOS's readlink has no `-f`, so walk the links by hand.
src="$0"
case "$src" in */*) ;; *) src="$(command -v "$src")" ;; esac   # found via PATH
while [ -L "$src" ]; do
  dir="$(cd -P "$(dirname "$src")" >/dev/null && pwd)"
  src="$(readlink "$src")"
  case "$src" in /*) ;; *) src="$dir/$src" ;; esac             # relative link target
done
BIN_DIR="$(cd -P "$(dirname "$src")" >/dev/null && pwd)"
REPO="$(dirname "$BIN_DIR")"

GATEWAY="${CHIKIN_GATEWAY:-http://localhost:8080}"
NAME="${CHIKIN_NAME:-inst-$PPID}"
# Gateway names must match [a-z0-9-]{1,32}. Fail closed on an out-of-charset or
# over-length CHIKIN_NAME rather than silently folding it (tr/cut) — folding is
# non-injective, so `work.alice` and `work_alice` would collapse onto the same
# browser + profile volume (CHK-011). Mirrors chikin-claude's check. The default
# inst-<ppid> is always valid.
if ! [[ "$NAME" =~ ^[a-z0-9-]{1,32}$ ]]; then
  echo "chikin-mcp: invalid CHIKIN_NAME '$NAME' (must be [a-z0-9-], 1-32 chars)" >&2
  exit 64
fi

URL="${GATEWAY}/b/${NAME}/"

# Supervisor loop (backstop). The bridge is self-healing: transient gateway/SSE
# failures are recovered IN-PROCESS, so it normally exits only on a clean client
# disconnect (exit 0). This loop exists purely for a HARD node crash — by NOT
# exec'ing, this bash process keeps Claude Code's stdio pipe open across a
# respawn, so the MCP server never disappears (which would deregister every tool
# until a manual /mcp reconnect). Clean exit (0) => client is gone, so stop.
#
# CRITICAL: the bridge MUST inherit our stdin (the MCP pipe from Claude Code).
# A non-interactive bash redirects a BACKGROUNDED job's stdin from /dev/null
# unless it is explicitly redirected — so we run the bridge in the background
# (so `wait` can be interrupted by SIGTERM for a clean shutdown) but pin its
# stdin back to ours with `0<&0`. Without this the bridge reads instant EOF and
# the handshake dies with "Connection closed".
# NB: guard the kill — an empty $child would make `kill 0` signal the whole
# process group (including our parent's session).
trap '[ -n "${child:-}" ] && kill "$child" 2>/dev/null; exit 0' TERM INT

backoff=1
while true; do
  node "$REPO/client/bridge.mjs" "$URL" 0<&0 &
  child=$!
  wait "$child"; rc=$?
  [ "$rc" -eq 0 ] && exit 0            # clean shutdown: client disconnected
  echo "chikin-mcp: bridge exited ($rc); respawning in ${backoff}s" >&2
  sleep "$backoff"
  backoff=$(( backoff < 16 ? backoff * 2 : 16 ))
done
